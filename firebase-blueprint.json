{
  "entities": {
    "AdminJob": {
      "title": "Admin Job",
      "description": "Job created by admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "reward": { "type": "number" },
        "link": { "type": "string" },
        "type": { "type": "string" },
        "requiredProofs": {
            "type": "array",
            "items": { "type": "string" }
        },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "bg": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["title", "description", "reward", "link", "type", "requiredProofs", "icon", "color", "bg", "status", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Task submission by a user",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "reward": { "type": "number" },
        "proofs": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "screenshot": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "timestamp" },
        "reviewedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["jobId", "userId", "userEmail", "title", "reward", "proofs", "status", "submittedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["task_approved", "task_rejected", "info"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["title", "message", "type", "read", "createdAt"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Public leaderboard data",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "bonus": { "type": "number" },
        "referrals": { "type": "number" },
        "totalIncome": { "type": "number" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["fullName", "bonus", "updatedAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account data including balances and referral code.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "description": "Email address"
        },
        "myReferCode": {
          "type": "string",
          "description": "Unique referral code for the user"
        },
        "usedReferCode": {
          "type": "string",
          "description": "Referral code used to sign up, or 'none'"
        },
        "balances": {
          "type": "object",
          "properties": {
            "main": {
              "type": "number"
            },
            "bonus": {
              "type": "number"
            },
            "referral": {
              "type": "number"
            }
          },
          "required": ["main", "bonus", "referral"]
        },
        "role": {
          "type": "string",
          "description": "User role, default 'user'"
        },
        "photoURL": {
          "type": "string",
          "description": "Profile picture URL"
        },
        "createdAt": {
          "type": "string",
          "format": "timestamp",
          "description": "Account creation timestamp"
        }
      },
      "required": ["fullName", "email", "myReferCode", "usedReferCode", "balances", "role", "createdAt"]
    },
    "TaskHistory": {
      "title": "Task History",
      "description": "A record of completed tasks",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "reward": { "type": "number" },
        "completedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["title", "reward", "completedAt"]
    },
    "TransactionHistory": {
      "title": "Transaction History",
      "description": "A record of balance changes",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "task", "referral"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["amount", "type", "status", "createdAt"]
    },
    "ReferralHistory": {
      "title": "Referral History",
      "description": "A record of referred users",
      "type": "object",
      "properties": {
        "referredEmail": { "type": "string" },
        "bonusEarned": { "type": "number" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["referredEmail", "bonusEarned", "createdAt"]
    },
    "MathHistory": {
      "title": "Math History",
      "description": "A record of completed math quizzes",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "userAnswer": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "reward": { "type": "number" },
        "completedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["question", "userAnswer", "correctAnswer", "reward", "completedAt"]
    },
    "SettingsSpin": {
      "title": "Spin Settings",
      "description": "Configuration for the spin wheel",
      "type": "object",
      "properties": {
        "rewards": {
          "type": "array",
          "items": { "type": "number" }
        },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["rewards", "updatedAt"]
    },
    "SettingsReferral": {
      "title": "Referral Settings",
      "description": "Configuration for referral fixed bonus and percentage commission",
      "type": "object",
      "properties": {
        "fixedBonus": { "type": "number" },
        "percentageCommission": { "type": "number" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["fixedBonus", "percentageCommission", "updatedAt"]
    },
    "SettingsBanner": {
      "title": "Banner Settings",
      "description": "Configuration for scrolling banner URL and text",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "link": { "type": "string" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["text", "link", "updatedAt"]
    },
    "Course": {
      "title": "Course/Tutorial",
      "description": "Educational help and video tutorials for using the app",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "videoLink": { "type": "string" },
        "category": { "type": "string", "enum": ["টাস্ক কমপ্লিট", "টাকা উইথড্র", "অন্যান্য"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["title", "description", "thumbnailUrl", "videoLink", "category", "status"]
    }
  },
  "firestore": {
    "/settings/banner": {
      "schema": {
        "$ref": "#/entities/SettingsBanner"
      },
      "description": "Global banner settings"
    },
    "/jobs/{jobId}": {
      "schema": {
        "$ref": "#/entities/AdminJob"
      },
      "description": "Collection of available jobs."
    },
    "/submissions/{submissionId}": {
      "schema": {
        "$ref": "#/entities/Submission"
      },
      "description": "Collection of task submissions."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Collection of user profiles."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": {
        "$ref": "#/entities/Notification"
      },
      "description": "Collection of user notifications."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": {
        "$ref": "#/entities/TaskHistory"
      },
      "description": "History of completed tasks for the user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/TransactionHistory"
      },
      "description": "History of transactions for the user."
    },
    "/users/{userId}/referrals/{referralId}": {
      "schema": {
        "$ref": "#/entities/ReferralHistory"
      },
      "description": "History of referrals by the user."
    },
    "/users/{userId}/mathHistory/{mathId}": {
      "schema": {
        "$ref": "#/entities/MathHistory"
      },
      "description": "History of completed math quizzes for the user."
    },
    "/leaderboard/{userId}": {
      "schema": {
        "$ref": "#/entities/LeaderboardEntry"
      },
      "description": "Public leaderboard data for users"
    },
    "/settings/spin": {
      "schema": {
        "$ref": "#/entities/SettingsSpin"
      },
      "description": "Global spin settings"
    },
    "/settings/referral": {
      "schema": {
        "$ref": "#/entities/SettingsReferral"
      },
      "description": "Global referral settings"
    },
    "/courses/{courseId}": {
      "schema": {
        "$ref": "#/entities/Course"
      },
      "description": "Collection of courses and educational tutorials."
    }
  }
}
