rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ১. সহায়তাকারী ফাংশনসমূহ (Helper Functions)
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.uid in ['CGsRdm6gLNZwnAzjkWtPQH0Z3IQ2', 'G0sRdm6gLNZwnAzjkWtPQH0Z3IQ2'] ||
        ('email' in request.auth.token && request.auth.token.email == 'mdekramhossain590@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'employee'])
      );
    }

    // রেকর্ড বা পে-লোডের মালিকানা যাচাই করার সাধারণ ফাংশন
    function isDataOwner(data) {
      return isAuth() && data != null && 'userId' in data && request.auth.uid == data.userId;
    }

    // ২. সিস্টেম সেটিংস ও অ্যাডমিন রুলস
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /admin/{document=**} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ৩. ইউজার প্রোফাইল এবং সকল সাব-কালেকশনসমূহ (সংক্ষিপ্ত ও নিরাপদ)
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isOwner(userId) || isAdmin());

      // সকল সাব-কালেকশন (tasks, transactions, referrals, notifications, mathHistory ইত্যাদি) স্বয়ংক্রিয়ভাবে কভার করবে
      match /{allSubcollections=**} {
        allow read, write: if isAuth() && (isOwner(userId) || isAdmin());
      }
    }

    // ৪. পাবলিক সার্ভিস কালেকশনসমূহ
    match /jobs/{jobId} {
      allow read: if isAuth();
      allow create: if isAdmin() || (isAuth() && request.resource.data.postedByUid == request.auth.uid && request.resource.data.status == 'pending');
      allow update, delete: if isAdmin();
    }
    match /giftCodes/{codeId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAuth();
    }

    match /courses/{courseId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /drive_offers/{offerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ৫. সিস্টেম, রিপোর্ট ও লিডারবোর্ড
    match /leaderboard/{userId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }
    match /system/{document=**} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /reports/{document=**} {
      allow read: if isAdmin() || isAuth(); 
      allow write: if isAdmin();
    }

    // ৬. সোশ্যাল পোস্ট এবং রিয়্যাকশনস
    match /social_posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.authorId;
      allow update: if isAuth();
      allow delete: if isAuth() && (request.auth.uid == resource.data.authorId || isAdmin());
      
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if isAuth() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
      match /likes/{userId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ৭. ইউজার রিকোয়েস্ট ও সাবমিশনসমূহ (Submissions, Payments, Support)
    match /submissions/{id} {
      allow read: if isAdmin() || isDataOwner(resource.data);
      allow create: if isAdmin() || isDataOwner(request.resource.data);
      allow update, delete: if isAdmin();
    }
    match /payment_requests/{id} {
      allow read: if isAdmin() || isDataOwner(resource.data);
      allow create: if isAdmin() || isDataOwner(request.resource.data);
      allow update, delete: if isAdmin();
    }
    match /support/{id} {
      allow read: if isAdmin() || isDataOwner(resource.data);
      allow create: if isAdmin() || isDataOwner(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
